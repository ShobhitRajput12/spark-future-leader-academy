MONGO_URI=mongodb://127.0.0.1:27017/spark_future_leader_academy
GEMINI_API_KEY=your_gemini_key_here
PORT=5000

# Optional override if needed:
# GEMINI_MODEL=gemini-pro-latest

# =========================
# RAG (PDF -> Vector Search)
# =========================

# Where PDFs are stored on disk (default: backend/uploads/defense_pdfs)
# RAG_UPLOAD_DIR=C:\\company\\defernce app\\backend\\uploads\\defense_pdfs

# Upload limit (MB)
# RAG_MAX_PDF_MB=50

# Chunking
# RAG_CHUNK_SIZE=900
# RAG_CHUNK_OVERLAP=150

# Gemini embedding model
# GEMINI_EMBEDDING_MODEL=text-embedding-004

# MongoDB Atlas Vector Search index config
# Create an Atlas Search index on collection: defense_documents
# index name must match MONGODB_VECTOR_INDEX
MONGODB_VECTOR_INDEX=defense_documents_vector_index
# MONGODB_VECTOR_DIMS=768
# MONGODB_VECTOR_SIMILARITY=cosine

# Auto indexing
# RAG_ENABLE_SCAN=true
# RAG_SCAN_BLOCKING=false
# RAG_SCAN_CONCURRENCY=2
# RAG_ENABLE_WATCH=true
# RAG_WATCH_STABLE_MS=1000
# RAG_EMBED_CONCURRENCY=2
# RAG_INSERT_BATCH=500


